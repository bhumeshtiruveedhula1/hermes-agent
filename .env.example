# Hermes AI Agent System — Environment Variables
# Copy this to .env and fill in your credentials
# NEVER commit .env to git — it contains secrets

# ── LLM (Ollama — local, no key needed) ──────────────────────────────────
# Model selected at startup via start_agent.bat (Qwen3:8B or Qwen2.5-Coder:14B)

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Get: t.me/BotFather → /newbot → copy token
# Get chat_id: message your bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates

# ── Gmail / Google Calendar ───────────────────────────────────────────────
# Place OAuth credentials file at: credentials/google_credentials.json
# Get: console.cloud.google.com → OAuth 2.0 Client IDs

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
# Get: github.com/settings/tokens → Personal access tokens

# ── WhatsApp (via Twilio Sandbox) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
# Get: twilio.com → Console → Account SID & Auth Token
# Sandbox: twilio.com/console/messaging/whatsapp/sandbox
# Send "join <word>" to +14155238886 on WhatsApp to activate sandbox

# ── Notion ────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get: notion.so/my-integrations → New integration → Internal Integration Token
# Then: Share each Notion page with your integration (Share → Invite → select integration)

# ── Spotify ───────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
# Get: developer.spotify.com/dashboard → Create App
# Add redirect URI in app settings: http://localhost:8888/callback
# First use: browser will open for OAuth. Token cached in .spotify_cache

# ── Slack ─────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
# Get: api.slack.com/apps → Create New App → From scratch
# OAuth & Permissions → Bot Token Scopes: channels:read channels:history chat:write groups:read
# Install to workspace → Bot User OAuth Token
# Add bot to channels: /invite @YourBotName in each Slack channel
